# Jarvis V2 — Variables d'environnement
# Copier vers .env et remplir les valeurs réelles
# NE JAMAIS commiter .env

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk_REPLACE_ME

# ── Base de données ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
SECRET_KEY=REPLACE_ME_min_32_chars

# ── n8n ──────────────────────────────────────────────────
N8N_API_URL=https://your-n8n-instance.com/api/v1
N8N_API_KEY=REPLACE_ME

# ── Smart Home (optionnel) ────────────────────────────────
SMART_HOME_API=http://localhost:8001

# ── Application ──────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Profil client ─────────────────────────────────────────
CLIENT_NAME=Abo
CLIENT_TIMEZONE=Europe/Paris
CLIENT_LANGUAGE=fr

# Boîtes mail
CLIENT_OUTLOOK_MAILBOX=REPLACE_ME@outlook.fr
CLIENT_SUMMARY_RECIPIENT=REPLACE_ME@outlook.fr
CLIENT_CR_RECIPIENT=REPLACE_ME@outlook.fr
CLIENT_GMAIL=REPLACE_ME@gmail.com

# Agenda
CLIENT_CALENDAR_ID=primary

# Classifier Outlook (mots-clés urgents, domaines exclus)
CLIENT_URGENCY_KEYWORDS=assignation,convocation,jugement,ordonnance,huissier,audience,appel,arrêt,décision,notification
CLIENT_EXCLUDED_DOMAINS=substack.com,mailchimp.com,sendgrid.net,newsletter,noreply

# Technique
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://jarvis.obyz.biz
EMAIL_ANALYSIS_CACHE_TTL=86400
EMAIL_INBOX_CACHE_TTL=120

# ── Next.js (frontend) ───────────────────────────────────
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost/ws
NEXT_PUBLIC_BACKEND_API_URL=http://localhost
