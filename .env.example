# Jarvis V2 — Variables d'environnement
# Copier vers .env et remplir les valeurs réelles
# NE JAMAIS commiter .env

# ── OpenAI ───────────────────────────────────────────────
OPENAI_API_KEY=sk_REPLACE_ME

# ── Base de données ───────────────────────────────────────
DATABASE_URL=postgresql://postgres:password@localhost:5432/jarvis
REDIS_URL=redis://localhost:6379

# ── JWT ──────────────────────────────────────────────────
SECRET_KEY=REPLACE_ME_min_32_chars

# ── Email classifier ─────────────────────────────────────
SUMMARY_RECIPIENT_EMAIL=ouat.abou34@outlook.fr

# ── n8n ──────────────────────────────────────────────────
N8N_API_URL=https://your-n8n-instance.com/api/v1
N8N_API_KEY=REPLACE_ME

# ── Smart Home (optionnel) ────────────────────────────────
SMART_HOME_API=http://localhost:8001

# ── Application ──────────────────────────────────────────
APP_ENV=development
DEBUG=true
LOG_LEVEL=INFO

# ── Next.js (frontend) ───────────────────────────────────
NEXT_PUBLIC_BACKEND_WS_URL=ws://localhost/ws
NEXT_PUBLIC_BACKEND_API_URL=http://localhost
